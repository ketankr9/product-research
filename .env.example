# Product Research Agent - Environment Configuration

# --- Search API Keys ---
# Tavily API key for web search (Required for web research)
# Get your key at: https://tavily.com/
TAVILY_API_KEY=

# --- LLM API Keys ---
# At least one of the following is required unless using a local model.

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google (Gemini)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=

# --- Default Models ---
# DEFAULT_MODEL_PROVIDER: "anthropic", "google", "openai", or "local"
DEFAULT_MODEL_PROVIDER=google
DEFAULT_ANTHROPIC_MODEL=
DEFAULT_GOOGLE_MODEL=
DEFAULT_OPENAI_MODEL=
DEFAULT_LOCAL_MODEL=

# --- Local Model Configuration ---
LOCAL_URL=http://localhost:1234/v1

